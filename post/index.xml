&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">sed -i &lt;span class="s2">&amp;#34;s/loglevel=3 quiet/loglevel=5 nowatchdog quiet/g&amp;#34;&lt;/span> /etc/default/grub &lt;span class="c1"># loglevel改为5是为了更方便排错，nowatchdog可以加快开关机速度&lt;/span>
