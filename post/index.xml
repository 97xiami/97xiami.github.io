&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-.vimrc" data-lang=".vimrc">&lt;span class="line">&lt;span class="cl">&lt;span class="c">&amp;#34;语法检测&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="k">syntax&lt;/span> &lt;span class="nx">enable&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c">&amp;#34;历史容量&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="k">set&lt;/span> &lt;span class="nx">history&lt;/span>&lt;span class="p">=&lt;/span>&lt;span class="m">100&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c">&amp;#34;检测文件类型&lt;/span>
