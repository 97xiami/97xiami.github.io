<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Posts on 瞎写</title><link>https://97xiami.github.io/post/</link><description>Recent content in Posts on 瞎写</description><generator>Hugo -- gohugo.io</generator><language>zh-cn</language><lastBuildDate>Sun, 22 Dec 2024 18:00:00 +0800</lastBuildDate><atom:link href="https://97xiami.github.io/post/index.xml" rel="self" type="application/rss+xml"/><item><title>alpine扩容分区</title><link>https://97xiami.github.io/p/alpine%E6%89%A9%E5%AE%B9%E5%88%86%E5%8C%BA/</link><pubDate>Sun, 22 Dec 2024 18:00:00 +0800</pubDate><guid>https://97xiami.github.io/p/alpine%E6%89%A9%E5%AE%B9%E5%88%86%E5%8C%BA/</guid><description>&lt;h1 id="安装resize2fs和growpart">安装resize2fs和growpart
&lt;/h1>&lt;div class="highlight">&lt;div class="chroma">
&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt">1
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="line">&lt;span class="cl">apk add e2fsprogs-extra cloud-utils-growpart
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div>&lt;h1 id="运行fdisk查看要扩容的磁盘名">运行fdisk查看要扩容的磁盘名
&lt;/h1>&lt;div class="highlight">&lt;div class="chroma">
&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt">1
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="line">&lt;span class="cl">fdisk -l
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div>&lt;h1 id="注意这里是指的sda的第3块分区不是sda3">注意这里是指的sda的第3块分区，不是sda3
&lt;/h1>&lt;div class="highlight">&lt;div class="chroma">
&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt">1
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="line">&lt;span class="cl">growpart /dev/sda &lt;span class="m">3&lt;/span>
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div>&lt;h1 id="重新定义sda3的ext4文件系统大小">重新定义sda3的ext4文件系统大小
&lt;/h1>&lt;div class="highlight">&lt;div class="chroma">
&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt">1
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="line">&lt;span class="cl">resize2fs /dev/sda3
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div></description></item><item><title>PVE合并local-lvm和local</title><link>https://97xiami.github.io/p/pve%E5%90%88%E5%B9%B6local-lvm%E5%92%8Clocal/</link><pubDate>Sun, 22 Dec 2024 17:57:00 +0800</pubDate><guid>https://97xiami.github.io/p/pve%E5%90%88%E5%B9%B6local-lvm%E5%92%8Clocal/</guid><description>&lt;h1 id="删除local-lvm并合并到local">删除local-lvm并合并到local
