&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">sort -u filename -o filename
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># `ip.txt`жҜҸиЎҢдёҖдёӘIPең°еқҖпјҢдёӢйқўзҡ„е‘Ҫд»ӨеҸҜд»Ҙе°ҶIPең°еқҖжҢүд»Һе°ҸеҲ°еӨ§жҺ’еәҸ&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># `-t`жҢҮе®ҡеҲҶеүІз¬Ұ&lt;/span>
