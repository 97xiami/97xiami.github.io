&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># еҲ йҷӨ`test.tar`дёӯзҡ„`filename`&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">tar --delete -f test.tar filename
