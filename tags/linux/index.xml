&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">sort -u ip.txt -o ip.txt -t &lt;span class="s1">&amp;#39;.&amp;#39;&lt;/span> -k1,1n -k2,2n -k3,3n -k4,4n
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
