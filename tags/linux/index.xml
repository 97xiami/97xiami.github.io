&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># з”Ё`:`еҲҶеүІе№¶жү“еҚ°`filename`з¬¬дәҢеҲ—е’ҢиЎҢеҸ·&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># `$0`иЎЁзӨәж•ҙиЎҢпјҢ`$1`иЎЁзӨәз¬¬дёҖеҲ—&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># `-F`жҢҮе®ҡеҲҶеүІз¬ҰпјҢй»ҳи®Өз©әж ј&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># `[,;]`жҢҮе®ҡеҲҶеүІз¬Ұдёә`,`жҲ–`;`&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">awk -F &lt;span class="s1">&amp;#39;:&amp;#39;&lt;/span> &lt;span class="s1">&amp;#39;{print NR, $2}&amp;#39;&lt;/span> filename
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># жү“еҚ°з¬¬дәҢеҲ—дёә`100`зҡ„иЎҢ&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># ж”ҜжҢҒ`&amp;gt;`,`&amp;gt;=`,`==`,`&amp;lt;=`,&amp;#39;&amp;lt;&amp;#39;,&amp;#39;!=&amp;#39;&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">awk &lt;span class="s1">&amp;#39;$2 == 100&amp;#39;&lt;/span> filename
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># жӯЈеҲҷиЎЁиҫҫејҸжү“еҚ°еҢ…еҗ«`text`иЎҢ,`!~`дёҚеҢ…еҗ«&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">awk &lt;span class="s1">&amp;#39;$1 ~ /text/ {print $0}&amp;#39;&lt;/span> filename
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># жү“еҚ°з¬¬дёҖеҲ—зӯүдәҺ &amp;#34;text&amp;#34; дё”з¬¬дәҢеҲ—еӨ§дәҺ 20 зҡ„иЎҢ&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># `||`жҲ–иҖ…&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">awk &lt;span class="s1">&amp;#39;$1 == &amp;#34;text&amp;#34; &amp;amp;&amp;amp; $2 &amp;gt; 100 {print $0}&amp;#39;&lt;/span> filename
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># жү“еҚ°з¬¬дёҖеҲ—дёҚжҳҜ`text`зҡ„иЎҢ&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">awk &lt;span class="s1">&amp;#39;!($1 == &amp;#34;apple&amp;#34;) {print $0}&amp;#39;&lt;/span> filename
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
